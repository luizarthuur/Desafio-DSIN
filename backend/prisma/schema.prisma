generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Cliente {
  id           Int            @id @default(autoincrement())
  nome         String
  email        String         @unique
  telefone     String
  senha        String
  role         String         @default("cliente") // "cliente" ou "admin"
  agendamentos Agendamento[]
}

model Servico {
  id         Int      @id @default(autoincrement())
  nome       String
  descricao  String?  // novo
  duracao    Int
  preco      Float
  imagemUrl  String?  // novo (opcional)
  itens      ItemAgendamento[]
}

model Agendamento {
  id                Int              @id @default(autoincrement())
  data              DateTime
  status            String           @default("pendente")
  formaPagamento    String?          // novo: DINHEIRO, CARTAO, PIX
  motivoCancelamento String?         // novo: justificativa quando cancelado
  createdAt         DateTime         @default(now())
  clienteId         Int
  cliente           Cliente          @relation(fields: [clienteId], references: [id])
  itens             ItemAgendamento[]
}

model ItemAgendamento {
  id            Int          @id @default(autoincrement())
  agendamentoId Int
  servicoId     Int
  statusServico String       @default("pendente")
  precoNaHora   Float
  agendamento   Agendamento  @relation(fields: [agendamentoId], references: [id])
  servico       Servico      @relation(fields: [servicoId], references: [id])
}

